# Rust / Cargo build output (includes cxx-qt generated C++, moc output and the
# compiled binary; everything here is regenerated by `cargo build`).
/target/

# Backup files from `cargo fmt` and rustfmt
**/*.rs.bk

# Cargo.lock is intentionally NOT ignored: this crate builds an application
# binary, so the exact dependency versions should be committed.

# Stray C/C++ object files (the real build goes through build.rs into target/)
*.o
*.obj
*.a

# Deployed/stripped binaries copied out for the device
/hello_remarkable
*.stripped

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
